{
  "manifest_version": 3,
  "name": "Prompt Builder for Cursor",
  "version": "1.0.0",
  "description": "Помогает формировать и сохранять промты для ИИ.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_title": "Prompt Builder",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}
